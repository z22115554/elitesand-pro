{
  "name": "elitesand-pro",
  "version": "0.9.2",
  "description": "Elitesand Pro - VTuber 直播動態歌詞助手",
  "license": "SEE LICENSE IN LICENSE",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "test": "node tests/run-tests.js",
    "audit:release": "npm audit --omit=dev --audit-level=low",
    "smoke:portable": "node tools/smoke-portable.js",
    "smoke:reliability": "node tools/reliability-smoke.js",
    "smoke:electron": "node tools/smoke-electron-shell.js",
    "shell": "electron electron/main.js",
    "package:portable": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/build-portable.ps1",
    "package:update": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/build-update.ps1",
    "package:installer": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/build-installer.ps1"
  },
  "dependencies": {
    "adm-zip": "^0.6.0",
    "express": "^4.21.0",
    "he": "^1.2.0",
    "iconv-lite": "^0.6.3",
    "kuromoji": "^0.1.2",
    "multer": "^2.2.0",
    "music-metadata": "^11.13.0",
    "node-fetch": "^2.7.0",
    "opencc-js": "^1.3.1",
    "pinyin-pro": "^3.28.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "soundtouchjs": "^0.3.0"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "build": {
    "appId": "com.elitesand.pro",
    "productName": "Elitesand Pro",
    "asar": false,
    "directories": {
      "output": "dist/releases/v${version}/installer"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/.electron-builder-resources/app-root",
        "to": "app-root",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "dist/.electron-builder-resources/app-root/node_modules",
        "to": "app-root/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "dist/.electron-builder-resources/tools",
        "to": "tools"
      },
      {
        "from": "dist/.electron-builder-resources/licenses",
        "to": "licenses"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    }
  }
}
